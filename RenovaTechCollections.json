db.createCollection("participantes", {
    "capped": false,
    "validator": {
        "$jsonSchema": {
            "bsonType": "object",
            "title": "participantes",
            "properties": {
                "_id": {
                    "bsonType": "objectId"
                },
                "dni": {
                    "bsonType": "string",
                    "maxLength": 8,
                    "minLength": 8,
                    "pattern": "^[0-9]{8}$"
                },
                "nombres": {
                    "bsonType": "string",
                    "maxLength": 100
                },
                "razon_social": {
                    "bsonType": [
                        "string",
                        "null"
                    ],
                    "maxLength": 200
                },
                "tipo": {
                    "bsonType": "string",
                    "enum": [
                        "Ciudadano",
                        "Empresa",
                        "Organizacion"
                    ]
                },
                "correo": {
                    "bsonType": "string"
                },
                "contrasena": {
                    "bsonType": "string",
                    "minLength": 8
                },
                "fecha_registro": {
                    "bsonType": "date"
                },
                "estado_cuenta": {
                    "bsonType": "string",
                    "enum": [
                        "Activo",
                        "Inactivo",
                        "Suspendido"
                    ]
                },
                "direcciones": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "string",
                        "maxLength": 150
                    }
                },
                "telefonos": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "string",
                        "maxLength": 9,
                        "minLength": 9,
                        "pattern": "^9[0-9]{8}$"
                    }
                }
            },
            "additionalProperties": false,
            "required": [
                "_id",
                "dni",
                "nombres",
                "tipo",
                "correo",
                "contrasena",
                "fecha_registro",
                "estado_cuenta",
                "direcciones",
                "telefonos"
            ]
        }
    },
    "validationLevel": "off",
    "validationAction": "warn"
});

db.participantes.createIndex({
    "_id": 1
},
{
    "name": "_id_"
});

db.participantes.createIndex({
    "dni": 1
},
{
    "name": "dni_1",
    "unique": true
});

db.participantes.createIndex({
    "correo": 1
},
{
    "name": "correo_1",
    "unique": true
});

