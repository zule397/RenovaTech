// CREACIÓN DE COLECCIONES, DOCUMENTOS Y SUBDOCUMENTOS CON VALIDACIONES, RELACIONES EMBEBIDAS E ÍNDICES
use RenovaTech;

db.createCollection("actividades", {
    "capped": false,
    "validator": {
        "$jsonSchema": {
            "bsonType": "object",
            "title": "actividades",
            "properties": {
                "_id": {
                    "bsonType": "objectId"
                },
                "proyecto_id": {
                    "bsonType": "objectId"
                },
                "nombre": {
                    "bsonType": "string",
                    "maxLength": 100
                },
                "descripcion": {
                    "bsonType": "string",
                    "maxLength": 300
                },
                "fecha_inicio": {
                    "bsonType": "date"
                },
                "fecha_fin": {
                    "bsonType": "date"
                },
                "estado": {
                    "bsonType": "string",
                    "enum": [
                        "Pendiente",
                        "En proceso",
                        "Finalizado"
                    ]
                },
                "responsables": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "properties": {
                            "participante_id": {
                                "bsonType": "objectId"
                            },
                            "nombres": {
                                "bsonType": "string"
                            }
                        },
                        "additionalProperties": false,
                        "required": [
                            "participante_id",
                            "nombres"
                        ]
                    }
                },
                "recursos": {
                    "bsonType": "array",
                    "additionalItems": true,
                    "items": {
                        "bsonType": "object",
                        "properties": {
                            "recurso_id": {
                                "bsonType": "objectId"
                            },
                            "nombre": {
                                "bsonType": "string"
                            }
                        },
                        "additionalProperties": false,
                        "required": [
                            "recurso_id",
                            "nombre"
                        ]
                    }
                }
            },
            "additionalProperties": false,
            "required": [
                "_id",
                "proyecto_id",
                "nombre",
                "descripcion",
                "fecha_inicio",
                "fecha_fin",
                "estado",
                "responsables",
                "recursos"
            ]
        }
    },
    "validationLevel": "off",
    "validationAction": "warn"
});

db.actividades.createIndex({
    "_id": 1
},
{
    "name": "_id_"
});

db.actividades.createIndex({
    "proyecto_id": 1
},
{
    "name": "proyecto_id_1"
});

